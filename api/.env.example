# API Service Configuration
ENVIRONMENT=production
LOG_LEVEL=INFO
API_HOST=0.0.0.0
SERVER_PORT=8000
CORS_ORIGINS=["https://your-domain.com"]

# Database (PostgreSQL)
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/model_pricing
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Cache (Redis)
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=900

# OpenRouter Integration
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODELS_PATH=/models
OPENROUTER_TIMEOUT_S=15
OPENROUTER_REFRESH_SECONDS=900
OPENROUTER_API_KEY=sk_live_your_openrouter_key_here

# Kilo Code Integration
KILO_API_KEY=your_kilo_api_key_here
KILO_PRICING_URL=https://kilo.ai/pricing
KILO_TIER=starter
KILO_DIFF_USER_AGENT=model-pricing-bot/0.1 (+your-domain.com)

# External Provider API Keys (optional - for account balance tracking)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_ADMIN_KEY=sk-proj-your-openai-admin-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
ANTHROPIC_ADMIN_KEY=sk-ant-your-anthropic-admin-key-here

# Email Configuration (for pricing reports)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@your-domain.com
SMTP_TO=["user@your-domain.com"]
SMTP_USE_TLS=true
SMTP_STARTTLS=false

# Model Ranking Configuration
RANK_INPUT_WEIGHT=0.30
RANK_OUTPUT_WEIGHT=0.70
RANK_MIN_CONTEXT_TOKENS=1000000
RANK_MAX_INPUT_PRICE=10.0
RANK_MAX_OUTPUT_PRICE=40.0
RANK_TOP_N=10

# Fee Configuration
OPENROUTER_PAYG_FEE_PCT=0.055
OPENROUTER_BYOK_FEE_PCT=0.05
